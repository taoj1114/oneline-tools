{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "oneline-tools",
  "main": "src/entry.worker.ts",
  "compatibility_date": "2024-11-01",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  }
}
